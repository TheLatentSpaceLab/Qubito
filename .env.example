# LLM provider: "ollama", "gemini", or "openrouter"
AI_CLIENT_PROVIDER=ollama

# Model name (depends on the provider)
AI_CLIENT_MODEL=cogito:3b

# Ollama host (only for ollama provider)
OLLAMA_HOST=http://localhost:11434

# Google API key (only for gemini provider)
# GOOGLE_API_KEY=your-google-api-key-here

# OpenRouter API key (only for openrouter provider)
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Default character (filename without .md, e.g. "riquelme", "macri", "joey")
# Leave empty or omit for random selection.
# DEFAULT_CHARACTER=riquelme

# Context window size in tokens (depends on the model)
CONTEXT_WINDOW=128000

# Embedding provider: "ollama" or "gemini"
# Defaults to AI_CLIENT_PROVIDER if omitted.
EMBEDDING_PROVIDER=ollama

# Embedding model (provider-specific)
# ollama default: nomic-embed-text
# gemini default: text-embedding-004
EMBEDDING_MODEL=nomic-embed-text

# Daemon settings
# QUBITO_DAEMON_HOST=127.0.0.1
# QUBITO_DAEMON_PORT=8741
