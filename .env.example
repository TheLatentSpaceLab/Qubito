# =============================================================================
# LLM Provider
# =============================================================================

# Provider: "ollama", "gemini", or "openrouter"
AI_CLIENT_PROVIDER=ollama

# Model name (depends on the provider)
AI_CLIENT_MODEL=cogito:3b

# Fallback models (comma-separated, OpenRouter only)
# AI_CLIENT_FALLBACK_MODEL=anthropic/claude-3-haiku,google/gemini-flash-1.5

# Ollama host (only for ollama provider)
OLLAMA_HOST=http://localhost:11434

# Google API key (only for gemini provider)
# GOOGLE_API_KEY=your-google-api-key-here

# OpenRouter API key (only for openrouter provider)
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Context window size in tokens
CONTEXT_WINDOW=128000

# =============================================================================
# Embeddings
# =============================================================================

# Embedding provider: "ollama" or "gemini" (defaults to AI_CLIENT_PROVIDER)
EMBEDDING_PROVIDER=ollama

# Embedding model (ollama: nomic-embed-text, gemini: text-embedding-004)
EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# Character
# =============================================================================

# Default character (filename without .md). Leave empty for random.
# DEFAULT_CHARACTER=joey

# =============================================================================
# Daemon
# =============================================================================

# Bind address and port
# QUBITO_DAEMON_HOST=127.0.0.1
# QUBITO_DAEMON_PORT=8741

# Idle session timeout in minutes (default: 30)
# QUBITO_SESSION_TIMEOUT=30

# =============================================================================
# Authentication (optional)
# =============================================================================

# Enable Bearer token auth for the daemon API
# QUBITO_AUTH_ENABLED=false

# Allow localhost to bypass auth (default: true)
# QUBITO_AUTH_LOCALHOST_BYPASS=true

# =============================================================================
# Channel Tokens
# =============================================================================

# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord bot token (from Discord Developer Portal)
# DISCORD_BOT_TOKEN=your-discord-bot-token
