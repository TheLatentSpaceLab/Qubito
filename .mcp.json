{
  "duckduckgo-search": {
    "command": "npx",
    "args": ["-y", "@oevortex/ddg_search@latest"]
  },
  "led-control": {
    "command": "uv",
    "args": ["run", "python", "src/mcp/led_server.py"]
  },
  "file-manager": {
    "command": "uv",
    "args": ["run", "python", "src/mcp/file_server.py"]
  },
  "shell": {
    "command": "uv",
    "args": ["run", "python", "src/mcp/shell_server.py"]
  }
}
